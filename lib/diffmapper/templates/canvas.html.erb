<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<style>
  :root {
    --bg: #1a1b26;
    --surface: #24283b;
    --surface-hover: #292e42;
    --border: #414868;
    --text: #c0caf5;
    --text-dim: #565f89;
    --text-bright: #e0e6ff;
    --green: #9ece6a;
    --green-bg: #1e2718;
    --green-border: rgba(158, 206, 106, 0.5);
    --orange: #e0af68;
    --orange-bg: #2a2518;
    --orange-border: rgba(224, 175, 104, 0.5);
    --red: #f7768e;
    --red-bg: #2a1a1e;
    --red-border: rgba(247, 118, 142, 0.5);
    --blue: #7aa2f7;
    --purple: #bb9af7;
    --cyan: #7dcfff;
    --connection-color: #7a88b0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    overflow: hidden;
    height: 100vh;
  }

  .top-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .top-bar h1 { font-size: 14px; font-weight: 600; color: var(--text-bright); }

  .top-bar .stats {
    font-size: 12px;
    color: var(--text-dim);
  }
  .top-bar .stats span { margin-right: 12px; }
  .top-bar .stats .additions { color: var(--green); }
  .top-bar .stats .deletions { color: var(--red); }

  .top-bar .controls { margin-left: auto; display: flex; gap: 8px; }

  .open-questions {
    font-size: 11px;
    color: var(--orange);
    font-weight: 500;
    padding: 2px 8px;
    background: rgba(224, 175, 104, 0.1);
    border-radius: 4px;
  }

  .top-bar button {
    background: var(--surface-hover);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    font-family: inherit;
  }
  .top-bar button:hover { background: var(--border); }

  .canvas {
    position: absolute;
    top: 46px; left: 0; right: 0; bottom: 0;
    overflow: auto;
  }
  .canvas.with-context {
    top: 46px; /* adjusted by JS after context bar renders */
  }

  .canvas-inner {
    position: relative;
    min-width: 2000px;
    min-height: 2000px;
    padding: 30px;
  }

  .connections {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .card {
    position: absolute;
    width: 420px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    z-index: 10;
    cursor: grab;
    user-select: none;
    transition: box-shadow 0.15s;
  }
  .card:hover { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); }
  .card.dragging { cursor: grabbing; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5); z-index: 50; opacity: 0.95; }

  .card.new { border-color: var(--green-border); background: var(--green-bg); }
  .card.modified { border-color: var(--orange-border); background: var(--orange-bg); }
  .card.deleted { border-color: var(--red-border); background: var(--red-bg); }
  .card.renamed { border-color: var(--orange-border); background: var(--orange-bg); }

  .card-header {
    padding: 10px 12px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 3px;
  }
  .status-dot.new { background: var(--green); }
  .status-dot.modified { background: var(--orange); }
  .status-dot.deleted { background: var(--red); }
  .status-dot.renamed { background: var(--orange); }

  .file-badge {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .badge-model { background: rgba(187, 154, 247, 0.2); color: var(--purple); }
  .badge-controller { background: rgba(122, 162, 247, 0.2); color: var(--blue); }
  .badge-serializer { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-service { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-config { background: rgba(224, 175, 104, 0.2); color: var(--orange); }
  .badge-component { background: rgba(158, 206, 106, 0.2); color: var(--green); }
  .badge-styles { background: rgba(187, 154, 247, 0.15); color: #c4a7f7; }
  .badge-spec { background: rgba(247, 118, 142, 0.2); color: var(--red); }
  .badge-migration { background: rgba(224, 175, 104, 0.2); color: var(--orange); }
  .badge-job { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-other { background: rgba(86, 95, 137, 0.3); color: var(--text-dim); }

  .filename {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-bright);
    word-break: break-all;
    line-height: 1.4;
  }

  .card-body {
    padding: 10px 12px;
    font-size: 12px;
    color: var(--text);
    line-height: 1.6;
  }

  .line-counts {
    font-size: 11px;
    color: var(--text-dim);
  }
  .line-counts .add { color: var(--green); }
  .line-counts .del { color: var(--red); }

  .changed-section {
    font-size: 11px;
    color: var(--cyan);
    padding: 1px 0;
    font-style: italic;
  }

  .card-summary {
    margin-top: 6px;
    font-size: 12px;
  }
  [contenteditable]:hover {
    outline: 1px dashed var(--border);
    outline-offset: 2px;
  }
  [contenteditable]:focus {
    outline: 1px solid var(--blue);
    outline-offset: 2px;
  }

  .card-details {
    margin-top: 6px;
    padding: 6px 8px;
    background: rgba(0,0,0,0.2);
    border-radius: 4px;
    border-left: 2px solid var(--border);
  }
  .card-details summary {
    cursor: pointer;
    font-size: 11px;
    color: var(--text-dim);
    font-weight: 500;
  }
  .card-details summary:hover { color: var(--text); }
  .card-details .detail-content {
    margin-top: 4px;
    font-size: 11px;
  }

  .annotation {
    margin-top: 6px;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
  }
  .annotation.observation { background: rgba(158,206,106,0.12); border-left: 2px solid var(--green); color: var(--green); }
  .annotation.question { background: rgba(122,162,247,0.12); border-left: 2px solid var(--blue); color: var(--blue); }
  .annotation.concern { background: rgba(247,118,142,0.12); border-left: 2px solid var(--red); color: var(--red); }

  .card-annotations {
    margin-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 6px;
  }
  .annotation-item {
    padding: 4px 8px;
    margin-bottom: 4px;
    border-radius: 4px;
    font-size: 11px;
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 4px;
  }
  .annotation-item.observation { background: rgba(158,206,106,0.12); border-left: 2px solid var(--green); color: var(--green); }
  .annotation-item.question { background: rgba(122,162,247,0.12); border-left: 2px solid var(--blue); color: var(--blue); }
  .annotation-item.concern { background: rgba(247,118,142,0.12); border-left: 2px solid var(--red); color: var(--red); }
  .annotation-text {
    flex: 1;
    cursor: text;
  }
  .annotation-delete {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
    padding: 0 2px;
  }
  .annotation-item:hover .annotation-delete { opacity: 0.7; }
  .annotation-delete:hover { opacity: 1 !important; }
  .add-annotation-btn {
    margin-top: 4px;
    padding: 3px 8px;
    font-size: 10px;
    background: transparent;
    border: 1px dashed var(--border);
    color: var(--text-dim);
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: left;
  }
  .add-annotation-btn:hover { border-color: var(--text-dim); color: var(--text); }
  .annotation-input-area { margin-top: 4px; }
  .annotation-input {
    width: 100%;
    padding: 4px 8px;
    font-size: 11px;
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 4px;
    font-family: inherit;
    resize: vertical;
    min-height: 32px;
  }
  .annotation-input:focus { outline: none; border-color: var(--blue); }
  .annotation-actions {
    display: flex;
    gap: 4px;
    margin-top: 4px;
  }
  .annotation-actions button {
    padding: 2px 8px;
    font-size: 10px;
    border-radius: 3px;
    cursor: pointer;
    font-family: inherit;
    border: 1px solid var(--border);
  }
  .annotation-save { background: rgba(122,162,247,0.2); color: var(--blue); }
  .annotation-save:hover { background: rgba(122,162,247,0.3); }
  .annotation-cancel { background: transparent; color: var(--text-dim); }
  .annotation-cancel:hover { color: var(--text); }
  .annotation-type-select {
    padding: 2px 4px;
    font-size: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 3px;
    font-family: inherit;
    cursor: pointer;
  }

  .card-diff {
    margin-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 6px;
    max-width: 100%;
    overflow: hidden;
  }
  .card-diff summary {
    cursor: pointer;
    font-size: 11px;
    color: var(--text-dim);
    font-weight: 500;
  }
  .card-diff summary:hover { color: var(--text); }
  .diff-content {
    margin-top: 6px;
    padding: 8px;
    background: rgba(0,0,0,0.3);
    border-radius: 4px;
    font-size: 11px;
    line-height: 1.5;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
    white-space: pre;
    word-break: keep-all;
  }
  .diff-line-add { color: var(--green); }
  .diff-line-del { color: var(--red); }
  .diff-line-hunk { color: var(--blue); font-weight: 500; }
  .diff-line-ctx { color: var(--text-dim); }

  .connections line {
    stroke: var(--connection-color);
    stroke-width: 1.5;
    stroke-dasharray: 6, 4;
  }
  .connections .conn-label {
    font-size: 10px;
    fill: var(--connection-color);
    font-family: inherit;
  }

  .legend {
    position: fixed;
    bottom: 16px; right: 16px;
    z-index: 100;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 11px;
  }
  .legend-item { display: flex; align-items: center; gap: 8px; margin: 3px 0; }
  .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  .cluster-label {
    position: absolute;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    z-index: 5;
    pointer-events: none;
  }

  .context-bar {
    position: fixed;
    top: 46px; left: 0; right: 0;
    z-index: 99;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 20px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease, padding 0.2s ease;
  }
  .context-bar.empty { display: none; }
  .context-bar.open {
    max-height: 200px;
    padding: 10px 20px;
  }
  .context-description {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
  }
  .context-toggle {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 12px;
    padding: 4px 6px;
    font-family: inherit;
  }
  .context-toggle:hover { color: var(--text); }
</style>
</head>
<body>

<div class="top-bar">
  <h1><%= title %></h1>
  <div class="stats">
    <span class="additions">+<%= stats[:additions] || 0 %></span>
    <span class="deletions">-<%= stats[:deletions] || 0 %></span>
    <span><%= stats[:files] || 0 %> files</span>
  </div>
  <%- if context && context[:description] -%>
  <button class="context-toggle" onclick="toggleContext()" id="contextToggle">▸ Details</button>
  <%- end -%>
  <span id="openQuestions" class="open-questions" style="display:none;"></span>
  <div class="controls">
    <button onclick="resetLayout()">Reset Layout</button>
    <button onclick="tidyLayout()">Tidy Layout</button>
    <button onclick="toggleAllDiffs()">Expand All Diffs</button>
    <button onclick="toggleConnections()">Toggle Lines</button>
  </div>
</div>

<%- has_context = context && context[:description] -%>
<div class="context-bar<%= ' empty' unless has_context %>" id="contextBar">
  <%- if has_context -%>
  <div class="context-description"><%= context[:description] %></div>
  <%- end -%>
</div>

<div class="canvas" id="canvas">
  <div class="canvas-inner" id="canvasInner" style="min-height: <%= canvas_min_height %>px;">
    <svg class="connections" id="connections"></svg>

    <%- files.each do |file| -%>
    <div class="card <%= status_class(file) %>"
         id="card-<%= file[:id] %>"
         style="visibility: hidden;">
      <div class="card-header">
        <span class="status-dot <%= status_class(file) %>"></span>
        <span class="file-badge <%= badge_class(file) %>"><%= file[:type] %></span>
        <span class="filename"><%= file[:path] %></span>
      </div>
      <div class="card-body">
        <div class="line-counts">
          <span class="add">+<%= file[:additions] %></span>
          <span class="del">-<%= file[:deletions] %></span>
        </div>
        <%- if file[:summary] -%>
        <div class="card-summary" contenteditable="true"><%= file[:summary] %></div>
        <%- end -%>
        <%- (file[:details] || []).each do |detail| -%>
        <%- if detail[:description] -%>
        <details class="card-details">
          <summary><%= detail[:label] %></summary>
          <div class="detail-content" contenteditable="true"><%= detail[:description] %></div>
        </details>
        <%- else -%>
        <div class="changed-section"><%= detail[:label] %></div>
        <%- end -%>
        <%- end -%>
        <div class="card-annotations">
          <div class="annotations-list">
            <%- (file[:annotations] || []).each do |ann| -%>
            <div class="annotation-item <%= ann[:type] %>" data-annotation-type="<%= ann[:type] %>">
              <span class="annotation-text" contenteditable="true"><%= ann[:text] %></span>
              <button class="annotation-delete" onclick="deleteAnnotation(this)">×</button>
            </div>
            <%- end -%>
          </div>
          <button class="add-annotation-btn" onclick="showAnnotationInput(this)">+ Add note</button>
          <div class="annotation-input-area" style="display:none;">
            <textarea class="annotation-input" placeholder="Add a note..." rows="2"></textarea>
            <div class="annotation-actions">
              <select class="annotation-type-select">
                <option value="observation">Observation</option>
                <option value="question">Question</option>
                <option value="concern">Concern</option>
              </select>
              <button class="annotation-save" onclick="saveAnnotation(this)">Save</button>
              <button class="annotation-cancel" onclick="cancelAnnotation(this)">Cancel</button>
            </div>
          </div>
        </div>
        <%- if file[:hunks] -%>
        <details class="card-diff" ontoggle="drawConnections()">
          <summary>View diff</summary>
          <pre class="diff-content"><%= format_hunks(file[:hunks]) %></pre>
        </details>
        <%- end -%>
      </div>
    </div>
    <%- end -%>
  </div>
</div>

<div class="legend">
  <div class="legend-item"><div class="legend-dot" style="background: var(--green);"></div> New file</div>
  <div class="legend-item"><div class="legend-dot" style="background: var(--orange);"></div> Modified</div>
  <div class="legend-item"><div class="legend-dot" style="background: var(--red);"></div> Deleted</div>
  <div style="border-top: 1px solid var(--border); margin: 6px 0;"></div>
  <div style="font-size: 10px; color: var(--text-dim);">Drag cards to rearrange</div>
</div>

<script>
const CONNECTIONS = <%= connections_json %>;
const GROUPS = <%= grouped_files_json %>;
const CARD_WIDTH = 420;
const GAP = 40;
const PAIR_GAP = 60;
const FILES_BY_ID = buildFileLookup();

function buildFileLookup() {
  const files = [
    ...GROUPS.paired.flatMap(([source, spec]) => [source, spec]),
    ...GROUPS.unpaired_sources,
    ...GROUPS.unpaired_specs
  ];

  return new Map(files.map(file => [file.id, file]));
}

function fileMeta(id) {
  return FILES_BY_ID.get(id) || { id: id, type: 'other', dir: 'other' };
}

// Drag & drop
let dragCard = null, dragOffsetX = 0, dragOffsetY = 0, topZ = 10;

document.querySelectorAll('.card').forEach(card => {
  card.addEventListener('mousedown', (e) => {
    topZ++;
    card.style.zIndex = topZ;
    if (['SUMMARY','BUTTON','TEXTAREA','INPUT'].includes(e.target.tagName) || e.target.isContentEditable) return;
    dragCard = card;
    dragCard.classList.add('dragging');
    const rect = card.getBoundingClientRect();
    const canvas = document.getElementById('canvas');
    dragOffsetX = e.clientX - rect.left + canvas.getBoundingClientRect().left - 30 + canvas.scrollLeft;
    dragOffsetY = e.clientY - rect.top + canvas.getBoundingClientRect().top - 30 + canvas.scrollTop;
  });
});

document.addEventListener('mousemove', (e) => {
  if (!dragCard) return;
  const canvas = document.getElementById('canvas');
  dragCard.style.left = (e.clientX - dragOffsetX + canvas.scrollLeft) + 'px';
  dragCard.style.top = (e.clientY - dragOffsetY + canvas.scrollTop) + 'px';
  drawConnections();
});

document.addEventListener('mouseup', () => {
  if (dragCard) {
    dragCard.classList.remove('dragging');
    topZ++;
    dragCard.style.zIndex = topZ;
    dragCard = null;
  }
});

// Connection lines
let connectionsVisible = true;

function getCardEdgePoint(id, targetPoint) {
  const el = document.getElementById('card-' + id);
  if (!el) return { x: 0, y: 0 };
  const left = parseFloat(el.style.left) || 0;
  const top = parseFloat(el.style.top) || 0;
  const w = el.offsetWidth, h = el.offsetHeight;
  const cx = left + w/2, cy = top + h/2;
  const dx = targetPoint.x - cx, dy = targetPoint.y - cy;
  const absDx = Math.abs(dx), absDy = Math.abs(dy);

  if (absDx * h > absDy * w) {
    const sign = dx > 0 ? 1 : -1;
    return { x: cx + sign * w/2, y: cy + dy * (w/2) / absDx };
  } else {
    const sign = dy > 0 ? 1 : -1;
    return { x: cx + dx * (h/2) / absDy, y: cy + sign * h/2 };
  }
}

function getCardCenter(id) {
  const el = document.getElementById('card-' + id);
  if (!el) return { x: 0, y: 0 };
  return {
    x: (parseFloat(el.style.left) || 0) + el.offsetWidth/2,
    y: (parseFloat(el.style.top) || 0) + el.offsetHeight/2
  };
}

function drawConnections() {
  const svg = document.getElementById('connections');
  svg.innerHTML = '';
  if (!connectionsVisible) return;

  CONNECTIONS.forEach(conn => {
    const fromCenter = getCardCenter(conn.from);
    const toCenter = getCardCenter(conn.to);
    const fromPt = getCardEdgePoint(conn.from, toCenter);
    const toPt = getCardEdgePoint(conn.to, fromCenter);

    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', fromPt.x);
    line.setAttribute('y1', fromPt.y);
    line.setAttribute('x2', toPt.x);
    line.setAttribute('y2', toPt.y);
    svg.appendChild(line);

    if (conn.label) {
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', (fromPt.x + toPt.x) / 2);
      text.setAttribute('y', (fromPt.y + toPt.y) / 2 - 6);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('class', 'conn-label');
      text.textContent = conn.label;
      svg.appendChild(text);
    }
  });
}

function toggleConnections() {
  connectionsVisible = !connectionsVisible;
  drawConnections();
}

// Reset
let initialPositions = {};

function storePositions() {
  document.querySelectorAll('.card').forEach(card => {
    initialPositions[card.id] = { left: card.style.left, top: card.style.top };
  });
}

function resetLayout() {
  document.querySelectorAll('.card').forEach(card => {
    if (initialPositions[card.id]) {
      card.style.left = initialPositions[card.id].left;
      card.style.top = initialPositions[card.id].top;
    }
  });
  drawConnections();
}

// Layout
function layoutCards() {
  document.querySelectorAll('.card').forEach(card => {
    card.style.visibility = 'visible';
  });

  document.querySelectorAll('.cluster-label').forEach(el => el.remove());

  seedByConnectedComponents();
  forceDirectedRefine();
}

function buildMeasuredNodeMap(readPositions = true) {
  const cards = Array.from(document.querySelectorAll('.card'));

  return new Map(cards.map(el => {
    const id = el.id.replace('card-', '');
    const meta = fileMeta(id);

    return [id, {
      el: el,
      id: id,
      x: readPositions ? (parseFloat(el.style.left) || 0) : 0,
      y: readPositions ? (parseFloat(el.style.top) || 0) : 0,
      w: el.offsetWidth,
      h: el.offsetHeight,
      type: meta.type,
      dir: meta.dir
    }];
  }));
}

function seedByConnectedComponents() {
  const nodeMap = buildMeasuredNodeMap(false);
  const units = buildLayoutUnits(nodeMap);
  const edges = buildLayoutEdges(nodeMap, units);
  const components = buildLayoutComponents(units, edges);
  const MAX_ROW_WIDTH = 2800;

  let x = GAP;
  let y = GAP;
  let rowHeight = 0;
  let maxX = 0;

  components.forEach(component => {
    layoutComponentAsStory(component);

    if (x > GAP && x + component.w > MAX_ROW_WIDTH) {
      x = GAP;
      y += rowHeight + GAP * 3;
      rowHeight = 0;
    }

    offsetComponent(component, x, y);
    component.units.forEach(unit => applyUnitPosition(unit));

    maxX = Math.max(maxX, x + component.w);
    rowHeight = Math.max(rowHeight, component.h);
    x += component.w + GAP * 3;
  });

  document.getElementById('canvasInner').style.minHeight = (y + rowHeight + 400) + 'px';
  document.getElementById('canvasInner').style.minWidth = Math.max(2500, maxX + GAP * 2) + 'px';
}

function buildLayoutComponents(units, edges) {
  const componentIds = buildConnectedComponents(units, edges);
  const grouped = new Map();

  units.forEach(unit => {
    const componentId = componentIds.get(unit);
    if (!grouped.has(componentId)) {
      grouped.set(componentId, { id: componentId, units: [], edges: [] });
    }

    grouped.get(componentId).units.push(unit);
  });

  edges.forEach(edge => {
    const componentId = componentIds.get(edge.source);
    grouped.get(componentId).edges.push(edge);
  });

  return Array.from(grouped.values()).sort(compareLayoutComponents);
}

function buildConnectedComponents(units, edges) {
  const adjacency = new Map(units.map(unit => [unit, new Set()]));
  edges.forEach(edge => {
    adjacency.get(edge.source).add(edge.target);
    adjacency.get(edge.target).add(edge.source);
  });

  const componentIds = new Map();
  let nextId = 0;

  units.forEach(unit => {
    if (componentIds.has(unit)) return;

    const stack = [unit];
    while (stack.length > 0) {
      const current = stack.pop();
      if (componentIds.has(current)) continue;

      componentIds.set(current, nextId);
      adjacency.get(current).forEach(neighbor => {
        if (!componentIds.has(neighbor)) stack.push(neighbor);
      });
    }

    nextId += 1;
  });

  return componentIds;
}

function compareLayoutComponents(a, b) {
  const zoneDelta = layoutZoneForComponent(a) - layoutZoneForComponent(b);
  if (zoneDelta !== 0) return zoneDelta;

  if (a.units.length !== b.units.length) return b.units.length - a.units.length;
  if (a.edges.length !== b.edges.length) return b.edges.length - a.edges.length;

  return componentPrimaryId(a).localeCompare(componentPrimaryId(b));
}

function layoutZoneForComponent(component) {
  const dirs = component.units.map(unit => unit.dir || '');
  const allSpecs = component.units.every(unit => unit.layoutType === 'spec');

  if (dirs.some(dir => dir.startsWith('frontend/'))) return 1;
  if (allSpecs) return 2;
  return 0;
}

function componentPrimaryId(component) {
  return component.units
    .map(unit => primaryIdForUnit(unit))
    .sort()[0] || '';
}

function layoutComponentAsStory(component) {
  const orderedUnits = buildComponentStoryOrder(component);
  let y = 0;
  let maxW = 0;

  orderedUnits.forEach((unit, index) => {
    unit.x = 0;
    unit.y = y;
    maxW = Math.max(maxW, unit.w);
    y += unit.h;
    if (index < orderedUnits.length - 1) y += GAP * 2;
  });

  component.units = orderedUnits;
  component.w = maxW;
  component.h = orderedUnits.length === 0 ? 0 : y;
}

function buildComponentStoryOrder(component) {
  const adjacency = new Map(component.units.map(unit => [unit, new Set()]));
  const counts = new Map(component.units.map(unit => [unit, { incoming: 0, outgoing: 0 }]));

  component.edges.forEach(edge => {
    adjacency.get(edge.source).add(edge.target);
    adjacency.get(edge.target).add(edge.source);
    counts.get(edge.source).outgoing += 1;
    counts.get(edge.target).incoming += 1;
  });

  const candidates = component.units.filter(unit => adjacency.get(unit).size <= 1);
  const startPool = candidates.length > 0 ? candidates : component.units;
  const orderedStartPool = startPool.sort((a, b) => compareTraversalUnits(a, b, adjacency, counts));
  const visited = new Set();
  const ordered = [];

  function visit(unit) {
    if (visited.has(unit)) return;

    visited.add(unit);
    ordered.push(unit);

    Array.from(adjacency.get(unit))
      .filter(neighbor => !visited.has(neighbor))
      .sort((a, b) => compareTraversalUnits(a, b, adjacency, counts))
      .forEach(visit);
  }

  orderedStartPool.forEach(visit);
  component.units
    .filter(unit => !visited.has(unit))
    .sort((a, b) => compareTraversalUnits(a, b, adjacency, counts))
    .forEach(visit);

  return ordered;
}

function compareTraversalUnits(a, b, adjacency, counts) {
  const startDelta = traversalStartBucket(a, counts) - traversalStartBucket(b, counts);
  if (startDelta !== 0) return startDelta;

  const typeDelta = traversalTypeBucket(a) - traversalTypeBucket(b);
  if (typeDelta !== 0) return typeDelta;

  const degreeDelta = adjacency.get(a).size - adjacency.get(b).size;
  if (degreeDelta !== 0) return degreeDelta;

  return primaryIdForUnit(a).localeCompare(primaryIdForUnit(b));
}

function traversalStartBucket(unit, counts) {
  const count = counts.get(unit) || { incoming: 0, outgoing: 0 };

  if (count.incoming === 0 && count.outgoing > 0) return 0;
  if (count.outgoing > 0) return 1;
  if (count.incoming > 0) return 2;
  return 3;
}

function traversalTypeBucket(unit) {
  switch (unit.layoutType) {
    case 'controller': return 0;
    case 'component': return 1;
    case 'service': return 2;
    case 'job': return 3;
    case 'model': return 4;
    case 'serializer': return 5;
    case 'spec': return 6;
    default: return 7;
  }
}

function primaryIdForUnit(unit) {
  return unit.primaryId || '';
}

function offsetComponent(component, offsetX, offsetY) {
  component.units.forEach(unit => {
    unit.x += offsetX;
    unit.y += offsetY;
  });
}

function buildClusters() {
  // Group paired files by source directory
  const dirMap = new Map();

  GROUPS.paired.forEach(([source, spec]) => {
    const dir = source.dir || 'other';
    if (!dirMap.has(dir)) dirMap.set(dir, { pairs: [], singles: [] });
    dirMap.get(dir).pairs.push([source, spec]);
  });

  // Add unpaired sources to their directory cluster
  GROUPS.unpaired_sources.forEach(file => {
    const dir = file.dir || 'other';
    if (!dirMap.has(dir)) dirMap.set(dir, { pairs: [], singles: [] });
    dirMap.get(dir).singles.push(file);
  });

  // Add unpaired specs — try to match to an existing cluster by dir
  GROUPS.unpaired_specs.forEach(file => {
    const dir = file.dir || 'other';
    // Spec dirs like "controllers/foo" might match source cluster
    const matchedDir = Array.from(dirMap.keys()).find(d => dir.includes(d) || d.includes(dir));
    const targetDir = matchedDir || dir;
    if (!dirMap.has(targetDir)) dirMap.set(targetDir, { pairs: [], singles: [] });
    dirMap.get(targetDir).singles.push(file);
  });

  // Convert to array with labels
  return Array.from(dirMap.entries()).map(([dir, data]) => ({
    label: formatClusterLabel(dir),
    pairs: data.pairs,
    singles: data.singles
  }));
}

function formatClusterLabel(dir) {
  return dir.split('/').map(part =>
    part.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
  ).join(' / ');
}

function forceDirectedRefine() {
  const nodeMap = buildMeasuredNodeMap();
  const allNodes = Array.from(nodeMap.values());
  if (allNodes.length === 0) return;

  // Build units: pairs become single units, singles are their own unit
  const units = buildLayoutUnits(nodeMap);
  const edges = buildLayoutEdges(nodeMap, units);

  // Initialize velocities
  units.forEach(u => { u.vx = 0; u.vy = 0; });

  // Simulation
  const ITERATIONS = 120;
  const REPULSION = 60000;
  const ATTRACTION = 0.004;
  const DIRECTIONAL_BIAS = 0.02;
  const DAMPING = 0.75;
  const MIN_DIST = 30;

  const cx = units.reduce((s, u) => s + u.x + u.w / 2, 0) / units.length;
  const cy = units.reduce((s, u) => s + u.y + u.h / 2, 0) / units.length;

  for (let iter = 0; iter < ITERATIONS; iter++) {
    units.forEach(u => { u.vx = 0; u.vy = 0; });

    // Repulsion between all unit pairs
    for (let i = 0; i < units.length; i++) {
      for (let j = i + 1; j < units.length; j++) {
        applyRepulsion(units[i], units[j], REPULSION, MIN_DIST);
      }
    }

    // Attraction along edges + directional bias
    edges.forEach(e => {
      applyAttraction(e.source, e.target, ATTRACTION);
      // For "calls" edges, bias caller above callee
      if (e.type === 'calls' || e.type === 'passes_prop') {
        const dy = e.target.y - e.source.y;
        if (dy < 100) {
          // Push target down, source up
          e.source.vy -= DIRECTIONAL_BIAS * (100 - dy);
          e.target.vy += DIRECTIONAL_BIAS * (100 - dy);
        }
      }
    });

    // Gentle gravity toward center
    units.forEach(u => {
      u.vx += (cx - (u.x + u.w / 2)) * 0.0005;
      u.vy += (cy - (u.y + u.h / 2)) * 0.0005;
    });

    // Apply velocities with cooling
    const cooling = 1 - (iter / ITERATIONS) * 0.7;
    units.forEach(u => {
      u.x += u.vx * DAMPING * cooling;
      u.y += u.vy * DAMPING * cooling;
    });
  }

  // Normalize: shift so minimum x,y is at GAP
  const minX = Math.min(...units.map(u => u.x));
  const minY = Math.min(...units.map(u => u.y));
  const shiftX = GAP - minX;
  const shiftY = GAP - minY;

  // Apply final positions back to DOM
  units.forEach(u => {
    u.x += shiftX;
    u.y += shiftY;
    applyUnitPosition(u);
  });

  // Resize canvas
  const maxX = Math.max(...units.map(u => u.x + u.w));
  const maxY = Math.max(...units.map(u => u.y + u.h));
  document.getElementById('canvasInner').style.minWidth = (maxX + GAP * 2) + 'px';
  document.getElementById('canvasInner').style.minHeight = (maxY + GAP * 2) + 'px';

  repositionClusterLabels(allNodes.map(n => ({
    ...n,
    x: parseFloat(n.el.style.left) || 0,
    y: parseFloat(n.el.style.top) || 0
  })));

  storePositions();
}

function buildLayoutUnits(nodeMap) {
  const units = [];
  const paired = new Set();

  // Test connections become rigid pairs
  CONNECTIONS.filter(c => c.type === 'test').forEach(c => {
    const source = nodeMap.get(c.to);  // the source file
    const spec = nodeMap.get(c.from);  // the spec file
    if (!source || !spec) return;

    paired.add(source.id);
    paired.add(spec.id);

    units.push({
      type: 'pair',
      source: source,
      spec: spec,
      primaryId: source.id,
      layoutType: source.type,
      dir: source.dir,
      x: Math.min(source.x, spec.x),
      y: Math.min(source.y, spec.y),
      w: source.w + PAIR_GAP + spec.w,
      h: Math.max(source.h, spec.h)
    });
  });

  // Unpaired nodes are their own units
  nodeMap.forEach((node, id) => {
    if (paired.has(id)) return;
    units.push({
      type: 'single',
      node: node,
      primaryId: node.id,
      layoutType: node.type,
      dir: node.dir,
      x: node.x,
      y: node.y,
      w: node.w,
      h: node.h
    });
  });

  return units;
}

function buildLayoutEdges(nodeMap, units) {
  const unitForNode = new Map();
  units.forEach(u => {
    if (u.type === 'pair') {
      unitForNode.set(u.source.id, u);
      unitForNode.set(u.spec.id, u);
    } else {
      unitForNode.set(u.node.id, u);
    }
  });

  // Only non-test connections (test connections are already rigid pairs)
  return CONNECTIONS
    .filter(c => c.type !== 'test')
    .map(c => ({
      source: unitForNode.get(c.from),
      target: unitForNode.get(c.to),
      type: c.type
    }))
    .filter(e => e.source && e.target && e.source !== e.target);
}

function applyUnitPosition(unit) {
  if (unit.type === 'pair') {
    unit.source.el.style.left = Math.round(unit.x) + 'px';
    unit.source.el.style.top = Math.round(unit.y) + 'px';
    unit.spec.el.style.left = Math.round(unit.x + unit.source.w + PAIR_GAP) + 'px';
    unit.spec.el.style.top = Math.round(unit.y) + 'px';
  } else {
    unit.node.el.style.left = Math.round(unit.x) + 'px';
    unit.node.el.style.top = Math.round(unit.y) + 'px';
  }
}

function applyRepulsion(a, b, strength, minDist) {
  // Use rectangle edge-to-edge distance, not center-to-center
  const ax1 = a.x, ay1 = a.y, ax2 = a.x + a.w, ay2 = a.y + a.h;
  const bx1 = b.x, by1 = b.y, bx2 = b.x + b.w, by2 = b.y + b.h;

  // Separation on each axis (negative = overlapping)
  const sepX = Math.max(bx1 - ax2, ax1 - bx2);
  const sepY = Math.max(by1 - ay2, ay1 - by2);
  const overlapping = sepX < minDist && sepY < minDist;

  // Direction from a center to b center
  const dx = (a.x + a.w / 2) - (b.x + b.w / 2);
  const dy = (a.y + a.h / 2) - (b.y + b.h / 2);
  const dist = Math.sqrt(dx * dx + dy * dy) || 1;

  if (overlapping) {
    // Strong push based on overlap amount
    const pushX = (minDist - sepX) * (dx >= 0 ? 1 : -1);
    const pushY = (minDist - sepY) * (dy >= 0 ? 1 : -1);
    a.vx += pushX * 0.3;
    a.vy += pushY * 0.3;
    b.vx -= pushX * 0.3;
    b.vy -= pushY * 0.3;
  } else {
    // Normal distance-based repulsion
    const force = strength / (dist * dist);
    a.vx += (dx / dist) * force;
    a.vy += (dy / dist) * force;
    b.vx -= (dx / dist) * force;
    b.vy -= (dy / dist) * force;
  }
}

function applyAttraction(a, b, strength) {
  const dx = (b.x + b.w / 2) - (a.x + a.w / 2);
  const dy = (b.y + b.h / 2) - (a.y + a.h / 2);
  a.vx += dx * strength;
  a.vy += dy * strength;
  b.vx -= dx * strength;
  b.vy -= dy * strength;
}

function repositionClusterLabels(nodes) {
  // Remove old labels and re-add based on where nodes actually ended up
  document.querySelectorAll('.cluster-label').forEach(el => el.remove());
  const clusters = buildClusters();
  const canvasInner = document.getElementById('canvasInner');

  clusters.forEach(cluster => {
    const clusterNodeIds = [
      ...cluster.pairs.flatMap(([s, t]) => [s.id, t.id]),
      ...cluster.singles.map(f => f.id)
    ];
    const clusterNodes = clusterNodeIds
      .map(id => nodes.find(n => n.id === id))
      .filter(Boolean);
    if (clusterNodes.length === 0) return;

    const minX = Math.min(...clusterNodes.map(n => n.x));
    const minY = Math.min(...clusterNodes.map(n => n.y));

    const label = document.createElement('div');
    label.className = 'cluster-label';
    label.textContent = cluster.label;
    label.style.left = minX + 'px';
    label.style.top = (minY - 20) + 'px';
    canvasInner.appendChild(label);
  });
}

function tidyLayout() {
  layoutCards();
  drawConnections();
}

function toggleAllDiffs() {
  const allDiffs = document.querySelectorAll('.card-diff');
  const anyOpen = Array.from(allDiffs).some(d => d.open);
  allDiffs.forEach(d => { d.open = !anyOpen; });
  setTimeout(() => { tidyLayout(); }, 50);
}

// Annotations (unified: LLM + user)
function showAnnotationInput(btn) {
  const area = btn.nextElementSibling;
  area.style.display = 'block';
  btn.style.display = 'none';
  area.querySelector('.annotation-input').focus();
}

function cancelAnnotation(btn) {
  const area = btn.closest('.annotation-input-area');
  const addBtn = area.previousElementSibling;
  area.querySelector('.annotation-input').value = '';
  area.style.display = 'none';
  addBtn.style.display = '';
}

function deleteAnnotation(btn) {
  btn.closest('.annotation-item').remove();
  updateQuestionCount();
}

function saveAnnotation(btn) {
  const area = btn.closest('.annotation-input-area');
  const input = area.querySelector('.annotation-input');
  const typeSelect = area.querySelector('.annotation-type-select');
  const text = input.value.trim();
  if (!text) return;

  const annType = typeSelect.value;
  const container = area.closest('.card-annotations');
  const list = container.querySelector('.annotations-list');

  const item = document.createElement('div');
  item.className = 'annotation-item ' + annType;
  item.setAttribute('data-annotation-type', annType);

  const textSpan = document.createElement('span');
  textSpan.className = 'annotation-text';
  textSpan.contentEditable = 'true';
  textSpan.textContent = text;
  item.appendChild(textSpan);

  const deleteBtn = document.createElement('button');
  deleteBtn.className = 'annotation-delete';
  deleteBtn.textContent = '\u00d7';
  deleteBtn.onclick = () => { deleteAnnotation(deleteBtn); };
  item.appendChild(deleteBtn);

  list.appendChild(item);
  input.value = '';
  typeSelect.value = 'observation';
  cancelAnnotation(btn);
  updateQuestionCount();
}

function updateQuestionCount() {
  const questions = document.querySelectorAll('.annotation-item.question');
  const concerns = document.querySelectorAll('.annotation-item.concern');
  const counter = document.getElementById('openQuestions');
  const total = questions.length + concerns.length;
  if (total > 0) {
    const parts = [];
    if (questions.length > 0) parts.push(questions.length + ' question' + (questions.length > 1 ? 's' : ''));
    if (concerns.length > 0) parts.push(concerns.length + ' concern' + (concerns.length > 1 ? 's' : ''));
    counter.textContent = parts.join(', ');
    counter.style.display = '';
  } else {
    counter.style.display = 'none';
  }
}

// Init
function adjustCanvasTop() {
  const bar = document.getElementById('contextBar');
  const canvas = document.getElementById('canvas');
  if (bar && !bar.classList.contains('empty')) {
    canvas.style.top = (46 + bar.offsetHeight) + 'px';
  } else {
    canvas.style.top = '46px';
  }
}

function toggleContext() {
  const bar = document.getElementById('contextBar');
  const btn = document.getElementById('contextToggle');
  bar.classList.toggle('open');
  btn.textContent = bar.classList.contains('open') ? '▾ Details' : '▸ Details';
  setTimeout(adjustCanvasTop, 220);
}

adjustCanvasTop();
layoutCards();
drawConnections();
updateQuestionCount();
window.addEventListener('resize', drawConnections);
document.querySelectorAll('details').forEach(d => {
  d.addEventListener('toggle', () => setTimeout(drawConnections, 10));
});
</script>
