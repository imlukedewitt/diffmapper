<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<script src="https://dagrejs.github.io/project/dagre/latest/dagre.min.js"></script>
<style>
  :root {
    --bg: #1a1b26;
    --surface: #24283b;
    --surface-hover: #292e42;
    --border: #414868;
    --text: #c0caf5;
    --text-dim: #565f89;
    --text-bright: #e0e6ff;
    --green: #9ece6a;
    --green-bg: #1e2718;
    --green-border: rgba(158, 206, 106, 0.5);
    --orange: #e0af68;
    --orange-bg: #2a2518;
    --orange-border: rgba(224, 175, 104, 0.5);
    --red: #f7768e;
    --red-bg: #2a1a1e;
    --red-border: rgba(247, 118, 142, 0.5);
    --blue: #7aa2f7;
    --purple: #bb9af7;
    --cyan: #7dcfff;
    --connection-color: #7a88b0;
    --conn-test: #f7768e;
    --conn-calls: #7aa2f7;
    --conn-renders: #9ece6a;
    --conn-passes-prop: #e0af68;
    --conn-styles: #bb9af7;
    --code-bg: rgba(0, 0, 0, 0.3);
  }

  [data-theme="light"] {
    --bg: #e8e8ec;
    --surface: #ffffff;
    --surface-hover: #f5f5f8;
    --border: #d0d4dc;
    --text: #343b58;
    --text-dim: #6b7394;
    --text-bright: #1a1b26;
    --green: #4e8c3f;
    --green-bg: #edf5eb;
    --green-border: rgba(78, 140, 63, 0.4);
    --orange: #b36b1a;
    --orange-bg: #fdf4e8;
    --orange-border: rgba(179, 107, 26, 0.4);
    --red: #c0392b;
    --red-bg: #fcecea;
    --red-border: rgba(192, 57, 43, 0.4);
    --blue: #2e59a8;
    --purple: #7c3aed;
    --cyan: #0d7fa5;
    --connection-color: #6b7394;
    --conn-test: #c0392b;
    --conn-calls: #2e59a8;
    --conn-renders: #4e8c3f;
    --conn-passes-prop: #b36b1a;
    --conn-styles: #7c3aed;
    --code-bg: rgba(0, 0, 0, 0.05);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    overflow: hidden;
    height: 100vh;
  }

  .top-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .top-bar h1 { font-size: 14px; font-weight: 600; color: var(--text-bright); }

  .top-bar .stats {
    font-size: 12px;
    color: var(--text-dim);
  }
  .top-bar .stats span { margin-right: 12px; }
  .top-bar .stats .additions { color: var(--green); }
  .top-bar .stats .deletions { color: var(--red); }

  .top-bar .controls { margin-left: auto; display: flex; gap: 6px; align-items: center; }
  .top-bar .controls .separator { width: 1px; height: 18px; background: var(--border); margin: 0 4px; }
  .zoom-level { font-size: 11px; color: var(--text-dim); min-width: 36px; text-align: center; cursor: pointer; }

  .open-questions {
    font-size: 11px;
    color: var(--orange);
    font-weight: 500;
    padding: 2px 8px;
    background: rgba(224, 175, 104, 0.1);
    border-radius: 4px;
  }

  .top-bar button {
    background: var(--surface-hover);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    font-family: inherit;
  }
  .top-bar button:hover { background: var(--border); }

  .canvas {
    position: absolute;
    top: 46px; left: 0; right: 320px; bottom: 0;
    overflow: auto;
  }
  .canvas.with-context {
    top: 46px; /* adjusted by JS after context bar renders */
  }

  .canvas-inner {
    position: relative;
    min-width: 2000px;
    min-height: 2000px;
    padding: 30px;
    transform-origin: 0 0;
  }

  .connections {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .card {
    position: absolute;
    width: 420px;
    min-width: 200px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    z-index: 10;
    cursor: grab;
    user-select: none;
    transition: box-shadow 0.15s;
    resize: both;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card:hover { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); }
  .card.dragging { cursor: grabbing; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5); z-index: 50; opacity: 0.95; }

  .card.new { border-color: var(--green-border); background: var(--green-bg); }
  .card.modified { border-color: var(--orange-border); background: var(--orange-bg); }
  .card.deleted { border-color: var(--red-border); background: var(--red-bg); }
  .card.renamed { border-color: var(--orange-border); background: var(--orange-bg); }

  .card-header {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .card-header-top {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .card-reviewed-check {
    width: 14px;
    height: 14px;
    accent-color: var(--green);
    cursor: pointer;
    flex-shrink: 0;
  }
  .card.reviewed { opacity: 0.6; }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-dot.new { background: var(--green); }
  .status-dot.modified { background: var(--orange); }
  .status-dot.deleted { background: var(--red); }
  .status-dot.renamed { background: var(--orange); }

  .file-badge {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .badge-model { background: rgba(187, 154, 247, 0.2); color: var(--purple); }
  .badge-controller { background: rgba(122, 162, 247, 0.2); color: var(--blue); }
  .badge-serializer { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-service { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-config { background: rgba(224, 175, 104, 0.2); color: var(--orange); }
  .badge-component { background: rgba(158, 206, 106, 0.2); color: var(--green); }
  .badge-styles { background: rgba(187, 154, 247, 0.15); color: #c4a7f7; }
  .badge-spec { background: rgba(247, 118, 142, 0.2); color: var(--red); }
  .badge-migration { background: rgba(224, 175, 104, 0.2); color: var(--orange); }
  .badge-job { background: rgba(125, 207, 255, 0.2); color: var(--cyan); }
  .badge-other { background: rgba(86, 95, 137, 0.3); color: var(--text-dim); }

  .filename {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-bright);
    word-break: break-all;
    line-height: 1.4;
    cursor: pointer;
  }
  .filename:hover { text-decoration: underline; }
  .filename-copied {
    font-size: 9px;
    color: var(--green);
    margin-left: 6px;
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .filename-copied.show { opacity: 1; }

  .card-body {
    padding: 10px 12px;
    font-size: 12px;
    color: var(--text);
    line-height: 1.6;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .line-counts {
    font-size: 11px;
    color: var(--text-dim);
  }
  .line-counts .add { color: var(--green); }
  .line-counts .del { color: var(--red); }

  .card-summary {
    margin-top: 6px;
    font-size: 12px;
  }
  .card-summary:empty::before {
    content: 'Add summary...';
    color: var(--text-dim);
    opacity: 0.5;
    font-style: italic;
  }
  [contenteditable]:hover {
    outline: 1px dashed var(--border);
    outline-offset: 2px;
  }
  [contenteditable]:focus {
    outline: 1px solid var(--blue);
    outline-offset: 2px;
  }

  .card-details {
    margin-top: 6px;
    padding: 6px 8px;
    background: var(--code-bg);
    border-radius: 4px;
    border-left: 2px solid var(--border);
    position: relative;
  }
  .card-details .detail-header {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .card-details .detail-label {
    flex: 1;
    min-width: 0;
    font-size: 11px;
    color: var(--text-dim);
    font-weight: 500;
  }
  .card-details .detail-delete {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
    padding: 0 2px;
  }
  .card-details:hover .detail-delete { opacity: 0.7; }
  .card-details .detail-delete:hover { opacity: 1 !important; }
  .card-details .detail-content {
    margin-top: 4px;
    font-size: 11px;
  }
  .card-details .detail-content:empty::before {
    content: 'Add content...';
    color: var(--text-dim);
    opacity: 0.5;
    font-style: italic;
  }
  .add-detail-btn {
    margin-top: 4px;
    padding: 3px 8px;
    font-size: 10px;
    background: transparent;
    border: 1px dashed var(--border);
    color: var(--text-dim);
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: left;
  }
  .add-detail-btn:hover { border-color: var(--text-dim); color: var(--text); }

  .annotation {
    margin-top: 6px;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
  }
  .annotation.note { background: rgba(158,206,106,0.12); border-left: 2px solid var(--green); color: var(--green); }
  .annotation.question { background: rgba(122,162,247,0.12); border-left: 2px solid var(--blue); color: var(--blue); }

  .card-annotations {
    margin-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 6px;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }
  .annotation-item {
    padding: 4px 8px;
    margin-bottom: 4px;
    border-radius: 4px;
    font-size: 11px;
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 4px;
  }
  .annotation-item.note { background: rgba(158,206,106,0.12); border-left: 2px solid var(--green); color: var(--green); }
  .annotation-item.question { background: rgba(122,162,247,0.12); border-left: 2px solid var(--blue); color: var(--blue); }
  .annotation-item.resolved { opacity: 0.5; }
  .annotation-item.resolved .annotation-text { text-decoration: line-through; }
  .annotation-resolve {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
    padding: 0 2px;
  }
  .annotation-item:hover .annotation-resolve { opacity: 0.7; }
  .annotation-resolve:hover { opacity: 1 !important; }
  .annotation-text {
    flex: 1;
    cursor: text;
  }
  .annotation-delete {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
    padding: 0 2px;
  }
  .annotation-item:hover .annotation-delete { opacity: 0.7; }
  .annotation-delete:hover { opacity: 1 !important; }
  .add-annotation-btn {
    margin-top: 4px;
    padding: 3px 8px;
    font-size: 10px;
    background: transparent;
    border: 1px dashed var(--border);
    color: var(--text-dim);
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: left;
  }
  .add-annotation-btn:hover { border-color: var(--text-dim); color: var(--text); }
  .annotation-input-area { margin-top: 4px; }
  .annotation-input {
    width: 100%;
    padding: 4px 8px;
    font-size: 11px;
    background: var(--code-bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 4px;
    font-family: inherit;
    resize: vertical;
    min-height: 32px;
  }
  .annotation-input:focus { outline: none; border-color: var(--blue); }
  .annotation-actions {
    display: flex;
    gap: 4px;
    margin-top: 4px;
  }
  .annotation-actions button {
    padding: 2px 8px;
    font-size: 10px;
    border-radius: 3px;
    cursor: pointer;
    font-family: inherit;
    border: 1px solid var(--border);
  }
  .annotation-save { background: rgba(122,162,247,0.2); color: var(--blue); }
  .annotation-save:hover { background: rgba(122,162,247,0.3); }
  .annotation-cancel { background: transparent; color: var(--text-dim); }
  .annotation-cancel:hover { color: var(--text); }
  .annotation-type-select {
    padding: 2px 4px;
    font-size: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 3px;
    font-family: inherit;
    cursor: pointer;
  }

  .card-diff {
    margin-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 6px;
    max-width: 100%;
    overflow: hidden;
    min-height: 0;
  }
  .card-diff summary {
    cursor: pointer;
    font-size: 11px;
    color: var(--text-dim);
    font-weight: 500;
  }
  .card-diff summary:hover { color: var(--text); }
  .diff-content {
    margin-top: 6px;
    padding: 8px;
    background: var(--code-bg);
    border-radius: 4px;
    font-size: 11px;
    line-height: 1.5;
    overflow-x: auto;
    overflow-y: auto;
    white-space: pre;
    word-break: keep-all;
  }
  .diff-line-add { color: var(--green); }
  .diff-line-del { color: var(--red); }
  .diff-line-hunk { color: var(--blue); font-weight: 500; }
  .diff-line-ctx { color: var(--text-dim); }

  .connections line {
    stroke: var(--connection-color);
    stroke-width: 1.5;
    stroke-dasharray: 6, 4;
  }
  .connections path {
    transition: opacity 0.2s, stroke-width 0.2s;
  }
  .connections .conn-label {
    font-size: 10px;
    fill: var(--text);
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .connections .conn-label-bg {
    fill: var(--bg);
    opacity: 0.85;
    rx: 3;
    ry: 3;
    transition: opacity 0.2s;
  }
  .connections.has-focus path,
  .connections.has-focus .conn-label,
  .connections.has-focus .conn-label-bg {
    opacity: 0.3;
  }
  .connections.has-focus path.focused {
    opacity: 1;
  }
  .connections.has-focus .conn-label.focused,
  .connections.has-focus .conn-label-bg.focused {
    opacity: 1;
  }



  .context-bar {
    position: fixed;
    top: 46px; left: 0; right: 0;
    z-index: 99;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 20px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease, padding 0.2s ease;
  }
  .context-bar.empty { display: none; }
  .context-bar.open {
    max-height: 200px;
    padding: 10px 20px;
  }
  .context-description {
    font-size: 12px;
    color: var(--text);
    line-height: 1.5;
  }
  .context-toggle {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 12px;
    padding: 4px 6px;
    font-family: inherit;
  }
  .context-toggle:hover { color: var(--text); }

  .sidebar {
    position: fixed;
    top: 46px;
    right: 0;
    width: 320px;
    height: calc(100vh - 46px);
    background: var(--surface);
    border-left: 1px solid var(--border);
    z-index: 200;
    display: flex;
    flex-direction: column;
    font-size: 12px;
  }
  .sidebar.open { display: flex; }
  .sidebar-header {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    gap: 8px;
  }
  .sidebar-tabs { display: flex; gap: 4px; flex: 1; }
  .sidebar-tab {
    padding: 4px 10px;
    font-size: 11px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    border-radius: 4px;
    cursor: pointer;
    font-family: inherit;
  }
  .sidebar-tab.active { background: var(--surface-hover); color: var(--text); border-color: var(--text-dim); }
  .sidebar-tab:hover { color: var(--text); }
  .sidebar-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-filter-pill {
    padding: 2px 8px;
    font-size: 10px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    font-family: inherit;
    text-transform: uppercase;
  }
  .sidebar-filter-pill.active { background: var(--surface-hover); color: var(--text); border-color: var(--text-dim); }
  .sidebar-filter-pill:hover { color: var(--text); }
  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }
  .sidebar-progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 12px 8px;
    font-size: 11px;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
  }
  .sidebar-check-all {
    font-size: 10px;
    padding: 2px 6px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    border-radius: 3px;
    cursor: pointer;
    font-family: inherit;
  }
  .sidebar-check-all:hover { color: var(--text); border-color: var(--text-dim); }
  .sidebar-group-header {
    font-size: 9px;
    font-weight: 600;
    color: var(--text-dim);
    padding: 10px 12px 4px;
    letter-spacing: 0.5px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sidebar-file-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    cursor: pointer;
    border-left: 3px solid transparent;
  }
  .sidebar-file-item:hover { background: var(--surface-hover); }
  .sidebar-file-item.reviewed { opacity: 0.5; }
  .sidebar-file-item .file-check {
    width: 14px;
    height: 14px;
    accent-color: var(--green);
    cursor: pointer;
    flex-shrink: 0;
  }
  .sidebar-file-item .file-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
    font-size: 12px;
  }
  .sidebar-file-item .file-path {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-dim);
    font-size: 10px;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.15s, opacity 0.15s;
  }
  .sidebar-file-item:hover .file-path {
    max-height: 20px;
    opacity: 1;
  }
  .sidebar-file-item .file-info {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .sidebar-file-item .file-badge-mini {
    font-size: 9px;
    padding: 1px 4px;
    border-radius: 3px;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .sidebar-file-item .question-indicator {
    font-size: 10px;
    color: var(--blue);
    flex-shrink: 0;
  }
  .sidebar-file-item.has-new { border-left-color: #73d677; }
  .sidebar-file-item.has-modified { border-left-color: #f0a020; }
  .sidebar-file-item.has-deleted { border-left-color: var(--red); }
  .sidebar-question-item {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    cursor: pointer;
  }
  .sidebar-question-item:hover { background: var(--surface-hover); }
  .sidebar-question-item.resolved { opacity: 0.5; }
  .sidebar-question-item .sq-file {
    font-size: 10px;
    color: var(--text-dim);
    margin-bottom: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sidebar-question-item .sq-text {
    color: var(--blue);
    font-size: 11px;
  }
  .sidebar-question-item.resolved .sq-text { text-decoration: line-through; color: var(--text-dim); }

</style>
</head>
<body>

<div class="top-bar">
  <h1><%= title %></h1>
  <div class="stats">
    <span class="additions">+<%= stats[:additions] || 0 %></span>
    <span class="deletions">-<%= stats[:deletions] || 0 %></span>
    <span class="files-toggle" onclick="toggleSidebar('files')" style="cursor:pointer;"><%= stats[:files] || 0 %> files</span>
  </div>
  <%- if context && context[:description] -%>
  <button class="context-toggle" onclick="toggleContext()" id="contextToggle">▸ Details</button>
  <%- end -%>
  <span id="openQuestions" class="open-questions" style="display:none;"></span>
  <div class="controls">
    <button onclick="resetLayout()">Auto Arrange</button>
    <span class="separator"></span>
    <button onclick="toggleAllDiffs()">Expand All Diffs</button>
    <button id="toggleConnBtn" onclick="toggleConnections()">Toggle Lines</button>
    <span class="separator"></span>
    <button id="themeBtn" onclick="cycleTheme()" title="Toggle theme">☾</button>
    <span class="separator"></span>
    <button onclick="zoomOut()" title="Zoom out">−</button>
    <span id="zoomLevel" class="zoom-level" onclick="zoomReset()" title="Reset to 100%">100%</span>
    <button onclick="zoomIn()" title="Zoom in">+</button>
    <span class="separator"></span>
    <button onclick="clearSavedState()">Clear Progress</button>
  </div>
</div>

<%- has_context = context && context[:description] -%>
<div class="context-bar<%= ' empty' unless has_context %>" id="contextBar">
  <%- if has_context -%>
  <div class="context-description"><%= context[:description] %></div>
  <%- end -%>
</div>

<div class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-tabs">
      <button class="sidebar-tab active" data-tab="files" onclick="switchSidebarTab('files')" id="tabFiles">Files</button>
      <button class="sidebar-tab" data-tab="questions" onclick="switchSidebarTab('questions')" id="tabQuestions">Questions</button>
    </div>
  </div>
  <div class="sidebar-filters" id="sidebarFilters"></div>
  <div class="sidebar-content" id="sidebarContent"></div>
</div>

<div class="canvas" id="canvas">
  <div class="canvas-inner" id="canvasInner" style="min-height: <%= canvas_min_height %>px;">
    <svg class="connections" id="connections">
      <defs>
        <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--connection-color)" />
        </marker>
        <marker id="arrowhead-test" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--conn-test)" />
        </marker>
        <marker id="arrowhead-calls" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--conn-calls)" />
        </marker>
        <marker id="arrowhead-renders" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--conn-renders)" />
        </marker>
        <marker id="arrowhead-passes_prop" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--conn-passes-prop)" />
        </marker>
        <marker id="arrowhead-styles" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--conn-styles)" />
        </marker>
      </defs>
    </svg>

    <%- files.each do |file| -%>
    <div class="card <%= status_class(file) %>"
         id="card-<%= file[:id] %>"
         style="visibility: hidden;">
      <div class="card-header">
        <div class="card-header-top">
          <input type="checkbox" class="card-reviewed-check" title="Mark as reviewed" onclick="toggleReviewed('<%= file[:id] %>', this.checked)">
          <span class="status-dot <%= status_class(file) %>"></span>
          <span class="file-badge <%= badge_class(file) %>"><%= file[:type] %></span>
        </div>
        <span class="filename" onclick="copyFilename(this, '<%= file[:path] %>')"><%= file[:path] %><span class="filename-copied">Copied!</span></span>
      </div>
      <div class="card-body">
        <div class="line-counts">
          <span class="add">+<%= file[:additions] %></span>
          <span class="del">-<%= file[:deletions] %></span>
        </div>
        <div class="card-summary" contenteditable="true"><%= file[:summary] %></div>
        <div class="card-details-list">
        <%- (file[:details] || []).each do |detail| -%>
        <div class="card-details">
          <div class="detail-header"><span class="detail-label" contenteditable="true"><%= detail[:label] %></span><button class="detail-delete" onclick="deleteDetail(this)">&times;</button></div>
          <%- if detail[:description] -%>
          <div class="detail-content" contenteditable="true"><%= detail[:description] %></div>
          <%- end -%>
        </div>
        <%- end -%>
        </div>
        <button class="add-detail-btn" onclick="addDetail(this)">+ Add detail</button>
        <div class="card-annotations">
          <div class="annotations-list">
            <%- (file[:annotations] || []).each do |ann| -%>
            <div class="annotation-item <%= ann[:type] %>" data-annotation-type="<%= ann[:type] %>">
              <span class="annotation-text" contenteditable="true"><%= ann[:text] %></span>
              <%- if ann[:type] == 'question' -%>
              <button class="annotation-resolve" title="Mark as resolved" onclick="toggleResolved(this)">✓</button>
              <%- end -%>
              <button class="annotation-delete" onclick="deleteAnnotation(this)">×</button>
            </div>
            <%- end -%>
          </div>
          <button class="add-annotation-btn" onclick="showAnnotationInput(this)">+ Add note</button>
          <div class="annotation-input-area" style="display:none;">
            <textarea class="annotation-input" placeholder="Add a note..." rows="2"></textarea>
            <div class="annotation-actions">
              <select class="annotation-type-select">
                <option value="note">Note</option>
                <option value="question">Question</option>
              </select>
              <button class="annotation-save" onclick="saveAnnotation(this)">Save</button>
              <button class="annotation-cancel" onclick="cancelAnnotation(this)">Cancel</button>
            </div>
          </div>
        </div>
        <%- if file[:hunks] -%>
        <details class="card-diff" ontoggle="drawConnections()">
          <summary>View diff</summary>
          <pre class="diff-content"><%= format_hunks(file[:hunks]) %></pre>
        </details>
        <%- end -%>
      </div>
    </div>
    <%- end -%>
  </div>
</div>

<script>
const CONNECTIONS = <%= connections_json %>;
const GROUPS = <%= grouped_files_json %>;
const STORAGE_KEY = <%= storage_key.to_json %>;
<%= File.read(File.join(TEMPLATE_DIR, "canvas.js")) %>
</script>
</body>
</html>
