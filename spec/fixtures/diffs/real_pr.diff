@@ -45,6 +45,37 @@ RSpec.describe "Archiving a team project", type: :feature do
       expect(page).to have_content("Project archived successfully")
     end
   end
+
+  context "when the project is a child of a team project" do
+    let(:project) { create(:project, :child, team_project: team_project) }
+
+    it "shows the skip check option" do
+      visit archive_path(project)
+
+      expect(page).to have_content("Skip completion check")
+    end
+
+    it "hides the skip check option for parent projects" do
+      parent = create(:project, :parent, team_project: team_project)
+      visit archive_path(parent)
+
+      expect(page).not_to have_content("Skip completion check")
+    end
+
+    it "skips check when selected" do
+      visit archive_path(project)
+
+      check "Skip completion check"
+      click_button "Archive Project"
+
+      expect(page).to have_content("Project archived successfully")
+      expect(project.reload.subtasks).to all(
+        have_attributes(force_completed: true)
+      )
+    end
+
+    it "does not skip check by default" do
+      visit archive_path(project)
+      expect(find_field("Skip completion check")).not_to be_checked
+    end
+  end
 end
