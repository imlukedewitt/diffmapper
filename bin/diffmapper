#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/diffmapper"
require_relative "../lib/diffmapper/parser"
require "json"

diff_text = $stdin.read

if diff_text.strip.empty?
  warn "Usage: git diff --no-ext-diff main...branch | diffmapper parse"
  exit 1
end

result = Diffmapper::Parser.new(diff_text).call
puts JSON.pretty_generate(result)
